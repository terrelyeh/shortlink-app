# ===========================================
# Database (PostgreSQL)
# ===========================================
# Supabase: Project Settings → Database → Connection string → URI
# 格式: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://user:password@localhost:5432/shortlink?schema=public"

# ===========================================
# NextAuth.js
# ===========================================
# 產生方式: openssl rand -base64 32
# Vercel 設定: Settings → Environment Variables → 貼上產生的值
AUTH_SECRET="your-auth-secret-here"

# Google OAuth
# 取得方式: https://console.cloud.google.com/apis/credentials
# 1. 建立 OAuth 2.0 Client ID（Web application）
# 2. Authorized redirect URI 加入:
#    - http://localhost:3000/api/auth/callback/google（本地開發）
#    - https://你的domain.vercel.app/api/auth/callback/google（Production）
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# 可選: Email 白名單（逗號分隔，大小寫不敏感）
# 設了就只有清單內 email 能登入；留空或不設就開放所有 Google 帳號
# 範例：ALLOWED_EMAILS="alice@company.com,bob@partner.com,demo@contractor.io"
# ALLOWED_EMAILS=""

# ===========================================
# Application
# ===========================================
# 應用的完整 URL（不含結尾斜線）
# 本地: http://localhost:3000
# Vercel: https://你的domain.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 短網址的完整前綴（用於 UI 顯示和 QR Code 生成）
# 本地: http://localhost:3000/s
# Vercel: https://你的domain.vercel.app/s
NEXT_PUBLIC_SHORT_URL="http://localhost:3000/s"

# IP 匿名化用的 Salt（隱私保護，不可外洩）
# 產生方式: openssl rand -hex 32
# 注意: Production 必填，否則 redirect 會報錯
IP_HASH_SALT="your-random-salt-here"

# ===========================================
# Upstash Redis (選配 - 快取加速)
# ===========================================
# 免費方案: https://console.upstash.com/
# 建 database 後到「REST API」區塊拿這兩個值。
# 留空 app 還是能跑，只是分析頁查詢不會快取。
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your-rest-token"
